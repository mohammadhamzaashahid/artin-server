generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum OtpPurpose {
  SIGNUP_VERIFY
  PASSWORD_RESET
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LectureStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaKind {
  AUDIO
  VIDEO
  IMAGE
  DOCUMENT
}

enum BatchStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MediaProvider {
  LOCAL
  R2
  S3
}

enum MediaUploadStatus {
  PENDING
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum PriceType {
  ONE_TIME
  SUBSCRIPTION
}

enum BillingInterval {
  MONTH
  YEAR
}

enum PurchaseStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum PaymentProvider {
  STRIPE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PUBLISH
  UNPUBLISH
  UPLOAD
  REORDER
  REFUND
  CANCEL
}

enum BookStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BookAudioStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BookOrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum LiveClassStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  username        String?   @unique
  firstName       String
  lastName        String
  passwordHash    String
  role            UserRole  @default(USER)
  emailVerifiedAt DateTime?
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?

  stripeCustomerId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  otps                 EmailOtp[]
  coursesCreated       Course[]            @relation("CourseCreatedBy")
  liveClassesCreated   LiveClass[]         @relation("LiveClassCreatedBy")
  booksCreated         Book[]              @relation("BookCreatedByAdmin")
  mediaCreated         MediaAsset[]        @relation("MediaCreatedBy")
  purchases            Purchase[]
  subscriptions        CourseSubscription[]
  liveClassPurchases   LiveClassPurchase[]
  lectureProgress      LectureProgress[]
  auditLogs            AdminAuditLog[]     @relation("AdminAuditUser")
  refreshTokens        RefreshToken[]
  bookOrders           BookOrder[]         @relation("UserBookOrders")

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailOtp {
  id         String     @id @default(cuid())
  userId     String?
  email      String
  otpHash    String
  purpose    OtpPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose])
  @@index([expiresAt])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses Course[]

  @@index([slug])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses CourseTag[]

  @@index([slug])
}

model CourseTag {
  courseId String
  tagId    String

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
  @@index([tagId])
}

model Course {
  id               String       @id @default(cuid())
  slug             String       @unique
  title            String
  subtitle         String?
  shortDescription String?
  description      String?
  status           CourseStatus @default(DRAFT)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  thumbnailImageAssetId        String?
  bannerImageAssetId           String?
  outlineDocumentAssetId       String?

  thumbnailImageAsset        MediaAsset? @relation("CourseThumbnail", fields: [thumbnailImageAssetId], references: [id], onDelete: SetNull)
  bannerImageAsset           MediaAsset? @relation("CourseBanner", fields: [bannerImageAssetId], references: [id], onDelete: SetNull)
  outlineDocumentAsset       MediaAsset? @relation("CourseOutlineDocument", fields: [outlineDocumentAssetId], references: [id], onDelete: SetNull)

  createdByAdminId String?
  createdByAdmin   User? @relation("CourseCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)

  publishedAt DateTime?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags          CourseTag[]
  lectures      Lecture[]
  prices        CoursePrice[]
  purchases     Purchase[]
  subscriptions CourseSubscription[]
  progress      LectureProgress[]
  flyerAssets   CourseFlyerAsset[]
  batches       CourseBatch[]
  liveClasses   LiveClass[]

  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
  @@index([deletedAt])
}

model Lecture {
  id            String        @id @default(cuid())
  courseId      String
  title         String
  description   String?
  lectureOrder  Int
  isPreviewFree Boolean       @default(false)
  status        LectureStatus @default(DRAFT)

  audioMediaAssetId String?
  videoMediaAssetId String?

  audioMediaAsset MediaAsset? @relation("LectureAudio", fields: [audioMediaAssetId], references: [id], onDelete: SetNull)
  videoMediaAsset MediaAsset? @relation("LectureVideo", fields: [videoMediaAssetId], references: [id], onDelete: SetNull)

  durationSeconds Int?
  deletedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LectureProgress[]

  @@unique([courseId, lectureOrder])
  @@index([courseId])
  @@index([status])
  @@index([isPreviewFree])
  @@index([deletedAt])
}

model MediaAsset {
  id               String            @id @default(cuid())
  provider         MediaProvider     @default(R2)
  bucketName       String?
  objectKey        String
  publicUrl        String?
  originalFilename String?
  mimeType         String
  fileSizeBytes    BigInt?
  durationSeconds  Int?
  mediaKind        MediaKind
  uploadStatus     MediaUploadStatus @default(PENDING)

  createdByAdminId String?
  createdByAdmin   User? @relation("MediaCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseThumbnails        Course[]              @relation("CourseThumbnail")
  courseBanners           Course[]              @relation("CourseBanner")
  courseOutlineDocuments  Course[]              @relation("CourseOutlineDocument")
  courseFlyerAssets       CourseFlyerAsset[]
  lectureAudios           Lecture[]             @relation("LectureAudio")
  lectureVideos           Lecture[]             @relation("LectureVideo")
  bookCoverImages         BookCoverImage[]      @relation("BookCoverImageAsset")
  bookAudioFiles          BookAudioFile[]       @relation("BookAudioFileAsset")
  liveClassBanners        LiveClass[]           @relation("LiveClassBanner")
  liveClassMaterials      LiveClassMaterial[]

  @@index([objectKey])
  @@index([mediaKind])
  @@index([uploadStatus])
}

model CoursePrice {
  id              String          @id @default(cuid())
  courseId        String
  priceType       PriceType
  amount          Decimal         @db.Decimal(10, 2)
  currency        String          @default("USD")
  billingInterval BillingInterval?

  stripeProductId String?
  stripePriceId   String? @unique

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course        Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  purchases     Purchase[]
  subscriptions CourseSubscription[]

  @@index([courseId])
  @@index([priceType])
  @@index([isActive])
}

model Purchase {
  id            String         @id @default(cuid())
  userId        String
  courseId      String
  coursePriceId String?

  provider PaymentProvider @default(STRIPE)

  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique

  amount   Decimal        @db.Decimal(10, 2)
  currency String         @default("USD")
  status   PurchaseStatus @default(PENDING)

  purchasedAt DateTime?
  refundedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  coursePrice CoursePrice? @relation(fields: [coursePriceId], references: [id], onDelete: SetNull)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model CourseSubscription {
  id            String @id @default(cuid())
  userId        String
  courseId      String
  coursePriceId String?

  provider PaymentProvider @default(STRIPE)

  stripeCustomerId        String?
  stripeSubscriptionId    String? @unique
  stripeCheckoutSessionId String? @unique

  status SubscriptionStatus @default(INCOMPLETE)

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  cancelAtPeriodEnd Boolean   @default(false)
  canceledAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  coursePrice CoursePrice? @relation(fields: [coursePriceId], references: [id], onDelete: SetNull)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([currentPeriodEnd])
}

model LectureProgress {
  id        String @id @default(cuid())
  userId    String
  courseId  String
  lectureId String

  lastPositionSeconds Int      @default(0)
  completed           Boolean  @default(false)
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@unique([userId, lectureId])
  @@index([userId, courseId])
  @@index([lectureId])
}

model PaymentEvent {
  id            String          @id @default(cuid())
  provider      PaymentProvider @default(STRIPE)
  stripeEventId String          @unique
  eventType     String
  payloadJson   Json
  processedAt   DateTime?
  createdAt     DateTime        @default(now())

  @@index([eventType])
  @@index([processedAt])
}

model AdminAuditLog {
  id          String      @id @default(cuid())
  adminUserId String?
  action      AuditAction
  entityType  String
  entityId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  adminUser User? @relation("AdminAuditUser", fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model CourseFlyerAsset {
  id           String @id @default(cuid())
  courseId     String
  mediaAssetId String
  displayOrder Int    @default(0)

  createdAt DateTime @default(now())

  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([courseId, mediaAssetId])
  @@index([courseId])
  @@index([mediaAssetId])
}

model CourseBatch {
  id               String      @id @default(cuid())
  courseId         String
  title            String?
  startDate        DateTime
  endDate          DateTime
  numberOfSessions Int
  fee              Decimal     @db.Decimal(10, 2)
  currency         String      @default("USD")
  description      String?
  status           BatchStatus @default(UPCOMING)
  isActive         Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([status])
  @@index([startDate])
  @@index([isActive])
}

model Book {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String?
  status      BookStatus @default(DRAFT)
  price       Decimal    @default(0) @db.Decimal(10, 2)
  currency    String     @default("USD")

  createdByAdminId String?
  createdByAdmin   User?   @relation("BookCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)

  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  coverImages BookCoverImage[]
  audioFiles  BookAudioFile[]
  orders      BookOrder[]

  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

model BookCoverImage {
  id           String     @id @default(cuid())
  bookId       String
  book         Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  mediaAssetId String
  mediaAsset   MediaAsset @relation("BookCoverImageAsset", fields: [mediaAssetId], references: [id], onDelete: Cascade)
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())

  @@unique([bookId, mediaAssetId])
  @@index([bookId])
}

model BookAudioFile {
  id              String          @id @default(cuid())
  bookId          String
  book            Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  audioOrder      Int
  isPreviewFree   Boolean         @default(false)
  status          BookAudioStatus @default(DRAFT)

  audioMediaAssetId String?
  audioMediaAsset   MediaAsset?  @relation("BookAudioFileAsset", fields: [audioMediaAssetId], references: [id], onDelete: SetNull)

  durationSeconds Int?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([bookId, audioOrder])
  @@index([bookId])
  @@index([status])
  @@index([isPreviewFree])
  @@index([deletedAt])
}

model BookOrder {
  id      String          @id @default(cuid())
  userId  String
  user    User            @relation("UserBookOrders", fields: [userId], references: [id], onDelete: Cascade)
  bookId  String
  book    Book            @relation(fields: [bookId], references: [id])

  status  BookOrderStatus @default(PENDING)

  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(10, 2)
  currency    String  @default("USD")

  deliveryName       String
  deliveryEmail      String
  deliveryPhone      String
  deliveryAddress    String
  deliveryCity       String
  deliveryState      String?
  deliveryPostalCode String?
  deliveryCountry    String  @default("Pakistan")
  deliveryNotes      String?

  adminNotes  String?

  processedAt DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([bookId])
  @@index([status])
  @@index([createdAt])
}

model LiveClass {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  description String?

  startDate    DateTime
  endDate      DateTime
  timeDuration Int

  joiningLink String?

  status LiveClassStatus @default(DRAFT)

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  bannerImageAssetId String?
  bannerImageAsset   MediaAsset? @relation("LiveClassBanner", fields: [bannerImageAssetId], references: [id], onDelete: SetNull)

  createdByAdminId String?
  createdByAdmin   User?   @relation("LiveClassCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)

  publishedAt DateTime?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prices    LiveClassPrice[]
  purchases LiveClassPurchase[]
  materials LiveClassMaterial[]

  @@index([status])
  @@index([startDate])
  @@index([courseId])
  @@index([deletedAt])
}

model LiveClassMaterial {
  id           String @id @default(cuid())
  liveClassId  String
  mediaAssetId String
  displayOrder Int    @default(0)

  createdAt DateTime @default(now())

  liveClass  LiveClass  @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([liveClassId, mediaAssetId])
  @@index([liveClassId])
}

model LiveClassPrice {
  id          String  @id @default(cuid())
  liveClassId String
  amount      Decimal @db.Decimal(10, 2)
  currency    String  @default("USD")

  stripeProductId String?
  stripePriceId   String? @unique

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  liveClass LiveClass          @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  purchases LiveClassPurchase[]

  @@index([liveClassId])
  @@index([isActive])
}

model LiveClassPurchase {
  id               String  @id @default(cuid())
  userId           String
  liveClassId      String
  liveClassPriceId String?

  provider PaymentProvider @default(STRIPE)

  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique

  amount   Decimal        @db.Decimal(10, 2)
  currency String         @default("USD")
  status   PurchaseStatus @default(PENDING)

  purchasedAt DateTime?
  refundedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  liveClass      LiveClass       @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  liveClassPrice LiveClassPrice? @relation(fields: [liveClassPriceId], references: [id], onDelete: SetNull)

  @@unique([userId, liveClassId])
  @@index([userId])
  @@index([liveClassId])
  @@index([status])
}